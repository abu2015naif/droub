rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "abu2015naif@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        (request.auth.token.email == "abu2015naif@gmail.com" && request.auth.token.email_verified == true) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (
          (!get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(['permissions'])) ?
            (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'staff']) :
            (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.get(permission, false) == true)
        )
      );
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: /users/{userId}
    // Fields: uid, email, displayName, photoURL, role, permissions
    //
    // Collection: /products/{productId}
    // Fields: name, price, description, images, categories, stock_status
    //
    // Collection: /orders/{orderId}
    // Fields: userId, items, total, status, createdAt
    //
    // Collection: /banners/{bannerId}
    // Fields: url, title, subtitle, link, order, active, createdAt, updatedAt
    //
    // Collection: /showrooms/{showroomId}
    // Fields: city, locationLink, whatsapp, phone, active
    //
    // Collection: /bank_accounts/{accountId}
    // Fields: bankName, accountName, accountNumber, iban, active
    // ===============================================================

    function isValidBanner(data) {
      return data.url is string && data.url.size() > 0 &&
             data.order is number &&
             data.active is bool &&
             (!('title' in data) || data.title is string) &&
             (!('subtitle' in data) || data.subtitle is string) &&
             (!('link' in data) || data.link is string);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || hasPermission('employees');
      
      match /favorites/{productId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if hasPermission('products');
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasPermission('orders'));
      allow create: if isAuthenticated();
      allow update, delete: if hasPermission('orders');
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if hasPermission('banners') && isValidBanner(request.resource.data);
    }

    match /showrooms/{showroomId} {
      allow read: if true;
      allow write: if hasPermission('showrooms');
    }

    match /bank_accounts/{accountId} {
      allow read: if true;
      allow write: if hasPermission('settings');
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if hasPermission('settings');
    }
  }
}
